# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# RESEND_API_KEY: Required for sending emails via the contact form.
RESEND_API_KEY="re_..."

# CONTENTFUL_SPACE_ID: Required for fetching content from Contentful CMS
CONTENTFUL_SPACE_ID="your_space_id"

# CONTENTFUL_ACCESS_TOKEN: Required for fetching content from Contentful CMS
CONTENTFUL_ACCESS_TOKEN="your_access_token"
